{
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "automerge": false,
  "includePaths": [
    "argocd/manifests/**",
    "argocd/prod/**"
  ],
  "ignorePaths": [
    "argocd/manifests/prod/infra/synology/v1.21/**"
  ],
  "enabledManagers": [
    "kubernetes",
    "argocd",
    "helm-values"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/argocd/manifests/.+\\.ya?ml$/",
      "/argocd/prod/.+\\.ya?ml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/argocd/prod/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/argocd/manifests/.+/values\\.ya?ml$/",
      "/argocd/prod/.+/values\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Docker image updates"
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "groupName": "Helm chart updates"
    }
  ]
}
