{
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "automerge": false,
  "includePaths": [
    "argocd/manifests/**",
    "argocd/prod/**"
  ],
  "ignorePaths": [
    "argocd/manifests/prod/infra/synology/v1.21/**"
  ],
  "enabledManagers": [
    "kubernetes",
    "argocd",
    "helm-values"
  ],
  "kubernetes": {
    "fileMatch": [
      "argocd/manifests/.+\\.ya?ml$",
      "argocd/prod/.+\\.ya?ml$"
    ]
  },
  "argocd": {
    "fileMatch": [
      "argocd/prod/.+\\.ya?ml$"
    ]
  },
  "helm-values": {
    "fileMatch": [
      "argocd/manifests/.+values\\.ya?ml$",
      "argocd/prod/.+values\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "matchPackagePatterns": [
        "^ghcr\\.io/hotio/"
      ],
      "versioning": "regex:^release-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(\\.(?<build>\\d+))?$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["metabase/metabase"],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$",
      "allowedUpdateTypes": ["minor", "major"]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Docker image updates"
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "groupName": "Helm chart updates"
    }
  ]
}
