{
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "automerge": false,
  "includePaths": [
    "argocd/manifests/**",
    "argocd/prod/**"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Docker image updates",
      "matchPackageNames": [
        "/.*/"
      ]
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "groupName": "Helm chart updates",
      "matchPackageNames": [
        "/.*/"
      ]
    }
  ]
}
