{
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "automerge": false,
  "includePaths": [
    "argocd/manifests/**",
    "argocd/prod/**"
  ],
  "enabledManagers": [
    "kubernetes",
    "argocd",
    "helm-values",
    "custom.regex"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Docker image updates"
    },
    {
      "matchDatasources": [
        "helm"
      ],
      "groupName": "Helm chart updates"
    }
  ]
}
